# Ignore raw and processed data
data/raw/*
data/processed/*

# Ignore notebook checkpoints
notebooks/.ipynb_checkpoints/
*.ipynb_checkpoints

# Ignore reports generated during analysis
report/*.html
report/*.pdf
report/*.png
report/*.jpg

# Ignore Python cache and compiled files
__pycache__/
*.pyc
*.pyo
*.pyd

# Ignore environment and dependency files
.env
.venv/
venv/
*.egg-info/
*.egg

# Ignore OS-specific files
.DS_Store
Thumbs.db

